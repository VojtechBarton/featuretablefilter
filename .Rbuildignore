# Ignore version control and IDE files
.git
.gitignore
.claude
.idea
.dockerignore
.*\.Rproj$
^.*\.Rproj$

# Ignore build and check artifacts
.*\.tar\.gz$
^.*_Rcheck/$
^\.Rcheck/
.*\.Rout$
.*\.Rout\.save$
.*\.o$
.*\.so$
.*\.dll$

# IDE and editor files
.vscode/
.*\.swp$
.*\.swo$
.*~$
\.DS_Store$
Thumbs\.db$

# Temporary files
^tmp/$
^temp/
.*\.tmp$
\.Rplots\.pdf$

# Vignette caches
^vignettes/cache/

# Local configuration
\.local/

# Environment variables
\.env$

# Log files
.*\.log$

# Docker
\.dockerignore

# BiocCheck / R check output directories
.*\.BiocCheck$
^\.\.Rcheck/
^\.Rcheck/

# Pre-built vignettes (Bioconductor builds these)
^inst/doc/
^vignettes/.*\.html$

# Claude Code session data
.claude/

# Report outputs from pipeline examples
.*_filtering_report\..*$
^results/

# Data generation scripts
^data-raw/$
